#include "main.h"

/**
 *jack_bauer - function that prints all seceonds of the day
 *
 */
void jack_bauer(void)
{
	int i, j, k, l;

	for (i = 0;i < 3; i++)
	{
		for (j = 0; j <= 9; j++)
		{
			if ( i == 2 && j == 4)
				break;
			for (k = 0; k < 6; k++ )
			{
				for (l = 0;l < 10; l++)
				{
					_putchar(i + 48);
					_putchar(j + 48);
					_putchar(':');
					_putchar(k + 48);
					_putchar(l + 48);
					_putchar('\n');

				}

			}

		}

	}
}
