#include "main.h"

/**
 *print_triangle - prints a Right angle triangle
 *@size: the base of the triangle
 */

void print_triangle(int size)
{
	int x, y, z;

	if (size <= 0)
		_putchar(10);
	else
		for (x = 1; x <= size; x++)

		{
			for (y = 1; y <= size-x; y++)
				_putchar(32);
			for (z = 1; z <= x; z++)
				_putchar('#');
			_putchar(10);
		}
}
